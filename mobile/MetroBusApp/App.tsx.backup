/**
 * Metro Bus Management System - Mobile App
 * Real-time bus tracking, journey planning, traffic monitoring, analytics
 * Version: 2.0 - Complete Feature Parity with Web/Backend
 */

import React, { useEffect, useState, useCallback } from 'react';
import {
  SafeAreaView,
  StyleSheet,
  View,
  Text,
  ScrollView,
  TouchableOpacity,
  ActivityIndicator,
  StatusBar,
  useColorScheme,
  RefreshControl,
  Alert,
  Dimensions,
  Platform,
} from 'react-native';

// ==========================================
// TYPE DEFINITIONS
// ==========================================

interface Route {
  route_id: string;
  name: string;
  source: string;
  destination: string;
  total_distance: number;
  stops_count: number;
  active: boolean;
  color: string;
  background_buses: number;
}

interface Bus {
  bus_id: string;
  route_id: string;
  current_lat: number;
  current_lng: number;
  speed: number;
  status: string;
  direction: string;
  detailed_status?: string;
}

// ==========================================
// API SERVICE - COMPLETE WITH ALL ENDPOINTS
// ==========================================

class ApiService {
  private baseURL: string;

  constructor(baseURL: string) {
    this.baseURL = baseURL;
  }

  private async request(endpoint: string, options?: RequestInit) {
    try {
      const url = `${this.baseURL}${endpoint}`;
      const response = await fetch(url, {
        ...options,
        headers: {
          'Content-Type': 'application/json',
          ...options?.headers,
        },
      });
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }
      return await response.json();
    } catch (error) {
      console.error(`API Error [${endpoint}]:`, error);
      throw error;
    }
  }

  // ====== ROUTE MANAGEMENT ======
  async getRoutes() {
    return this.request('/api/routes');
  }

  async activateRoute(routeId: string, numBuses: number = 10) {
    return this.request('/api/routes/activate', {
      method: 'POST',
      body: JSON.stringify({ route_id: routeId, num_buses: numBuses }),
    });
  }

  async deactivateRoute(routeId: string) {
    return this.request('/api/routes/deactivate', {
      method: 'POST',
      body: JSON.stringify({ route_id: routeId }),
    });
  }

  async deactivateAllRoutes() {
    return this.request('/api/routes/deactivate-all', { method: 'POST' });
  }

  // ====== JOURNEY PLANNING ======
  async planJourney(originLat: number, originLng: number, destLat: number, destLng: number, preferences?: any) {
    return this.request('/api/journey/plan', {
      method: 'POST',
      body: JSON.stringify({
        origin_lat: originLat,
        origin_lng: originLng,
        destination_lat: destLat,
        destination_lng: destLng,
        preferences: preferences || { time_weight: 0.4, transfer_weight: 0.3 },
      }),
    });
  }

  async quickJourneyPlan(originLat: number, originLng: number, destLat: number, destLng: number) {
    return this.request('/api/journey/quick-plan', {
      method: 'POST',
      body: JSON.stringify({
        origin_lat: originLat,
        origin_lng: originLng,
        destination_lat: destLat,
        destination_lng: destLng,
      }),
    });
  }

  async getJourneyUpdates(journeyId: string) {
    return this.request(`/api/journey/${journeyId}/updates`);
  }

  async getTransferPoints() {
    return this.request('/api/journey/transfer-points');
  }

  async findNearbyStops(lat: number, lng: number, radiusKm: number = 0.5) {
    return this.request(`/api/journey/nearby-stops?lat=${lat}&lng=${lng}&radius_km=${radiusKm}`);
  }

  // ====== TRAFFIC & ETA ======
  async getCurrentTraffic() {
    return this.request('/api/traffic/current');
  }

  async getRouteTraffic(routeId: string) {
    return this.request(`/api/traffic/route/${routeId}`);
  }

  async getAllETAPredictions() {
    return this.request('/api/eta/all');
  }

  async getBusETA(busId: string) {
    return this.request(`/api/eta/bus/${busId}`);
  }

  // ====== SIMULATION & STATISTICS ======
  async getSimulationStatus() {
    return this.request('/api/simulation/status');
  }

  async getRouteStatistics() {
    return this.request('/api/routes/statistics');
  }

  async getBidirectionalStats(routeId: string) {
    return this.request(`/api/routes/${routeId}/bidirectional`);
  }

  async getBuses() {
    return this.request('/api/buses');
  }

  // ====== ADMIN FEATURES ======
  async getAdminStatistics() {
    return this.request('/api/admin/statistics');
  }

  async getAdminAlerts() {
    return this.request('/api/admin/alerts');
  }

  async getPerformanceMetrics() {
    return this.request('/api/admin/performance');
  }

  async sendAnnouncement(title: string, message: string, priority: string = 'normal') {
    return this.request('/api/admin/announcement', {
      method: 'POST',
      body: JSON.stringify({ title, message, priority, timestamp: new Date().toISOString() }),
    });
  }
}

const API_CONFIG = {
  // For Android Emulator
  BASE_URL: 'http://10.0.2.2:8000',
  // For Physical Device (uncomment and update IP)
  // BASE_URL: 'http://192.168.18.21:8000',
  WS_URL: 'ws://10.0.2.2:8000/ws/live-tracking',
};

const apiService = new ApiService(API_CONFIG.BASE_URL);

// ==========================================
// WEBSOCKET SERVICE
// ==========================================

class WebSocketService {
  private ws: WebSocket | null = null;
  private listeners: { [key: string]: Function[] } = {};
  private reconnectAttempts = 0;
  private maxReconnectAttempts = 5;

  connect() {
    try {
      this.ws = new WebSocket(API_CONFIG.WS_URL);

      this.ws.onopen = () => {
        console.log('âœ… WebSocket Connected');
        this.reconnectAttempts = 0;
        this.emit('connected', true);
      };

      this.ws.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          this.emit('message', data);
        } catch (error) {
          console.error('Error parsing WebSocket message:', error);
        }
      };

      this.ws.onerror = (error) => {
        console.error('âŒ WebSocket Error:', error);
        this.emit('error', error);
      };

      this.ws.onclose = () => {
        console.log('ðŸ”Œ WebSocket Disconnected');
        this.emit('connected', false);
        this.reconnect();
      };
    } catch (error) {
      console.error('Error creating WebSocket:', error);
      this.reconnect();
    }
  }

  reconnect() {
    if (this.reconnectAttempts < this.maxReconnectAttempts) {
      this.reconnectAttempts++;
      console.log(`ðŸ”„ Reconnecting... Attempt ${this.reconnectAttempts}`);
      setTimeout(() => this.connect(), 3000);
    }
  }

  on(event: string, callback: Function) {
    if (!this.listeners[event]) {
      this.listeners[event] = [];
    }
    this.listeners[event].push(callback);
  }

  emit(event: string, data: any) {
    if (this.listeners[event]) {
      this.listeners[event].forEach(callback => callback(data));
    }
  }

  disconnect() {
    if (this.ws) {
      this.ws.close();
      this.ws = null;
    }
  }
}

const wsService = new WebSocketService();

// ==========================================
// MAIN APP COMPONENT
// ==========================================

function App() {
  const isDarkMode = useColorScheme() === 'dark';
  const [routes, setRoutes] = useState<Route[]>([]);
  const [buses, setBuses] = useState<Bus[]>([]);
  const [isConnected, setIsConnected] = useState(false);
  const [isLoading, setIsLoading] = useState(false);
  const [refreshing, setRefreshing] = useState(false);

  useEffect(() => {
    // Initialize WebSocket
    wsService.connect();

    wsService.on('connected', (connected: boolean) => {
      setIsConnected(connected);
    });

    wsService.on('message', (data: any) => {
      if (data.buses) {
        setBuses(data.buses);
      }
      if (data.available_routes) {
        setRoutes(data.available_routes);
      }
    });

    // Load initial data
    loadRoutes();

    return () => {
      wsService.disconnect();
    };
  }, []);

  const loadRoutes = async () => {
    setIsLoading(true);
    try {
      const data = await apiService.getRoutes();
      setRoutes(data.routes || []);
    } catch (error) {
      Alert.alert('Error', 'Failed to load routes. Check if backend is running.');
    } finally {
      setIsLoading(false);
    }
  };

  const onRefresh = async () => {
    setRefreshing(true);
    await loadRoutes();
    setRefreshing(false);
  };

  const handleActivateRoute = async (routeId: string) => {
    try {
      await apiService.activateRoute(routeId);
      Alert.alert('Success', `Route ${routeId} activated!`);
      await loadRoutes();
    } catch (error) {
      Alert.alert('Error', 'Failed to activate route');
    }
  };

  const handleDeactivateRoute = async (routeId: string) => {
    try {
      await apiService.deactivateRoute(routeId);
      Alert.alert('Success', `Route ${routeId} deactivated!`);
      await loadRoutes();
    } catch (error) {
      Alert.alert('Error', 'Failed to deactivate route');
    }
  };

  return (
    <>
      <StatusBar barStyle={isDarkMode ? 'light-content' : 'dark-content'} />
      <SafeAreaView style={styles.container}>
        {/* Header */}
        <View style={styles.header}>
          <View>
            <Text style={styles.headerTitle}>Metro Bus</Text>
            <Text style={styles.headerSubtitle}>Live Tracking & Management</Text>
          </View>
          <View style={[
            styles.statusDot,
            { backgroundColor: isConnected ? '#28a745' : '#dc3545' }
          ]} />
        </View>

        {/* Stats Bar */}
        <View style={styles.statsContainer}>
          <View style={[styles.statCard, { backgroundColor: '#E8F0FE' }]}>
            <Text style={[styles.statValue, { color: '#667eea' }]}>
              {routes.length}
            </Text>
            <Text style={styles.statLabel}>ROUTES</Text>
          </View>
          <View style={[styles.statCard, { backgroundColor: '#E8F5E9' }]}>
            <Text style={[styles.statValue, { color: '#28a745' }]}>
              {buses.length}
            </Text>
            <Text style={styles.statLabel}>BUSES</Text>
          </View>
          <View style={[styles.statCard, { backgroundColor: '#FFF9E6' }]}>
            <Text style={[styles.statValue, { color: '#ffc107' }]}>
              {routes.filter(r => r.active).length}
            </Text>
            <Text style={styles.statLabel}>ACTIVE</Text>
          </View>
        </View>

        {/* Routes List */}
        <ScrollView
          style={styles.content}
          refreshControl={
            <RefreshControl refreshing={refreshing} onRefresh={onRefresh} />
          }
        >
          <Text style={styles.sectionTitle}>Available Routes</Text>

          {isLoading ? (
            <ActivityIndicator size="large" color="#667eea" style={styles.loader} />
          ) : routes.length === 0 ? (
            <View style={styles.emptyState}>
              <Text style={styles.emptyStateText}>No routes available</Text>
              <Text style={styles.emptyStateSubtext}>
                Make sure your backend is running
              </Text>
              <TouchableOpacity style={styles.retryButton} onPress={loadRoutes}>
                <Text style={styles.retryButtonText}>Retry Connection</Text>
              </TouchableOpacity>
            </View>
          ) : (
            routes.map(route => (
              <View
                key={route.route_id}
                style={[
                  styles.routeCard,
                  {
                    borderColor: route.active ? '#28a745' : '#e0e0e0',
                    backgroundColor: route.active ? '#f0fff4' : 'white',
                  }
                ]}
              >
                {/* Route Header */}
                <View style={styles.routeHeader}>
                  <Text style={[styles.routeId, { color: route.color || '#667eea' }]}>
                    {route.route_id}
                  </Text>
                  <View style={[
                    styles.statusBadge,
                    { backgroundColor: route.active ? '#28a745' : '#6c757d' }
                  ]}>
                    <Text style={styles.statusText}>
                      {route.active ? 'ACTIVE' : 'INACTIVE'}
                    </Text>
                  </View>
                </View>

                {/* Route Info */}
                <Text style={styles.routeName}>{route.name}</Text>
                <Text style={styles.routeDestination}>
                  {route.source} â†’ {route.destination}
                </Text>

                {/* Route Stats */}
                <View style={styles.routeStats}>
                  <Text style={styles.routeStat}>ðŸšŒ {route.background_buses} buses</Text>
                  <Text style={styles.routeStat}>ðŸ“ {route.stops_count} stops</Text>
                  <Text style={styles.routeStat}>
                    ðŸ“ {route.total_distance.toFixed(1)} km
                  </Text>
                </View>

                {/* Action Buttons */}
                {route.active ? (
                  <TouchableOpacity
                    style={[styles.actionButton, styles.deactivateButton]}
                    onPress={() => handleDeactivateRoute(route.route_id)}
                  >
                    <Text style={styles.actionButtonText}>ðŸ›‘ Deactivate Route</Text>
                  </TouchableOpacity>
                ) : (
                  <TouchableOpacity
                    style={[styles.actionButton, styles.activateButton]}
                    onPress={() => handleActivateRoute(route.route_id)}
                  >
                    <Text style={styles.actionButtonText}>â–¶ï¸ Activate Route</Text>
                  </TouchableOpacity>
                )}
              </View>
            ))
          )}

          {/* Active Buses Section */}
          {buses.length > 0 && (
            <View style={styles.busesSection}>
              <Text style={styles.sectionTitle}>Active Buses ({buses.length})</Text>
              {buses.slice(0, 5).map(bus => (
                <View key={bus.bus_id} style={styles.busCard}>
                  <View style={styles.busHeader}>
                    <Text style={styles.busId}>ðŸšŒ {bus.bus_id}</Text>
                    <Text style={styles.busSpeed}>{bus.speed.toFixed(0)} km/h</Text>
                  </View>
                  <Text style={styles.busStatus}>
                    {bus.detailed_status || bus.status}
                  </Text>
                  <Text style={styles.busDirection}>
                    Direction: {bus.direction === 'forward' ? 'â†’' : 'â†'} {bus.direction.toUpperCase()}
                  </Text>
                </View>
              ))}
            </View>
          )}
        </ScrollView>

        {/* Connection Status Footer */}
        <View style={styles.footer}>
          <Text style={styles.footerText}>
            {isConnected ? 'ðŸŸ¢ Connected to Server' : 'ðŸ”´ Disconnected'}
          </Text>
          <Text style={styles.footerSubtext}>
            {API_CONFIG.BASE_URL}
          </Text>
        </View>
      </SafeAreaView>
    </>
  );
}

